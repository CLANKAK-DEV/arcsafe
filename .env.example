# ArcSafe — deployment environment
#
# Copy this file to .env and fill it in:
#     cp .env.example .env
#
# .env is gitignored. Never commit it, never paste its contents into a chat,
# an issue, or a screenshot.

# ── Deployer key ────────────────────────────────────────────────────
# Private key of the account that pays gas to deploy the factory, with the
# 0x prefix. Use a throwaway key holding testnet funds only.
#
# This key deploys ArcSafeFactory and nothing else. The factory has no owner,
# no admin function and no upgrade path, so this key gains no authority over
# any safe created through it.
PRIVATE_KEY=

# ── Network ─────────────────────────────────────────────────────────
# Arc Testnet, chain ID 5042002. Verified via eth_chainId -> 0x4cef52.
ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# ── Optional demo safe ──────────────────────────────────────────────
# Deploys one extra safe with the owners below, for screenshots and manual
# testing. Leave false for a public deployment: end users choose their own
# owners in the web UI, and nothing here affects them.
DEPLOY_DEMO_SAFE=false

# Addresses are checked against their EIP-55 checksum. If one is rejected, do
# not just re-case it — confirm the hex digits against the wallet first. A
# mistyped owner is a permanently dead slot in the quorum.
OWNERS=
THRESHOLD=2

# ── Optional ────────────────────────────────────────────────────────
REPORT_GAS=false
