# ArcSafe frontend environment
#
# Copy to .env.local, which Next.js loads automatically:
#     cp .env.example .env.local
#
# NEXT_PUBLIC_* values are inlined into the JavaScript bundle at build time
# and are readable by anyone who loads the page. Never put a secret here —
# addresses and RPC URLs are public data, private keys are not.

# ── Deployed contracts ──────────────────────────────────────────────
# Fill these in only after the address passes:
#     SAFE=0x... npm run verify:deployment
#
# Leaving them blank is safe: the app starts with an empty address field and
# checks for bytecode before trusting whatever is entered.
NEXT_PUBLIC_SAFE_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=

# ── Hosting path ────────────────────────────────────────────────────
# The sub-path the site is served from. nginx on the VPS serves it at
# /arcsafe/, which is the default. Set to an empty string when serving from
# the domain root.
#
# Windows Git Bash rewrites a leading slash into a Windows path. If you set
# this there, prefix the command with MSYS_NO_PATHCONV=1.
BASE_PATH=/arcsafe
